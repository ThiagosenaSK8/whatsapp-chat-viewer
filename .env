# Database Configuration
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/whatsapp_chat
DB_POOL_SIZE=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Flask Configuration
SECRET_KEY=super-secret-key-change-immediately-in-production-abc123xyz789
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5000

# Logging Configuration
LOG_LEVEL=DEBUG
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Security Configuration
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Application Configuration
TIMEZONE=America/Sao_Paulo
MAX_CONTENT_LENGTH=16777216

# Webhook Configuration
WEBHOOK_URL=https://api.ilumin.app/webhook/7730fe92-3207-4611-acdf-30cc44d766aa
WEBHOOK_TIMEOUT=30

# Development Configuration
TEMPLATES_AUTO_RELOAD=True
EXPLAIN_TEMPLATE_LOADING=False